NODE_ENV=development
PORT=5001
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/braindump
JWT_SECRET=supersecretjwtkeythatshouldbechanged
JWT_EXPIRES_IN=7d

# AI
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
AI_PROVIDER=groq

CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=20

# Payment provider: lemonsqueezy (default) | stripe
PAYMENT_PROVIDER=lemonsqueezy

# ── Lemon Squeezy (recommended for Bangladesh) ──
# Get keys: https://app.lemonsqueezy.com/settings/api
# Create products: Plus $6/mo, Plus $58/yr, Pro $8/mo, Pro $76/yr
# Copy variant IDs from each product variant page
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_TEST_MODE=true
LEMONSQUEEZY_PLUS_MONTHLY_VARIANT_ID=
LEMONSQUEEZY_PLUS_ANNUAL_VARIANT_ID=
LEMONSQUEEZY_PRO_MONTHLY_VARIANT_ID=
LEMONSQUEEZY_PRO_ANNUAL_VARIANT_ID=

# ── Stripe (optional fallback) ──
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PLUS_PRICE_ID=price_...
STRIPE_PLUS_ANNUAL_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...

# Google Calendar (Pro)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5001/api/calendar/callback
